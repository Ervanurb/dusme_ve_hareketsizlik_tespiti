# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# Gerçek .env dosyası ASLA repoya/teslim paketine eklenmemelidir.
PORT=5000
DATABASE_URL=postgresql://kullanici:sifre@host:5432/veritabani
JWT_SECRET=guclu_rastgele_bir_anahtar
JWT_REFRESH_SECRET=baska_guclu_rastgele_bir_anahtar
DB_SSL=true

# Anomali tespiti eşikleri
FALL_THRESHOLD=1.6
INACTIVITY_SECONDS=30
MOVEMENT_EPSILON=0.08
INACTIVITY_COOLDOWN_SECONDS=120
